flowchart TD
    subgraph Customer["Customer"]
        REQ[Text Request\nitems · qty · deadline · date]
        RESP[Customer Response\nquote · rationale · delivery · status]
    end

    subgraph Orchestrator["Orchestrator Agent"]
        ORCH[Route & Coordinate\nextract dates · assemble response]
    end

    subgraph Inventory["Inventory Agent — stock & reordering only"]
        IA[Inventory Agent]
        T1[get_inventory_snapshot\n→ get_all_inventory]
        T2[check_items_availability\n→ get_stock_level]
        T3[place_restock_order\n→ create_transaction\n  get_cash_balance\n  get_supplier_delivery_date]
        T4[auto_restock_if_needed\n→ get_stock_level + T3]
    end

    subgraph Quoting["Quoting Agent — pricing only"]
        QA[Quoting Agent]
        T5[search_historical_quotes\n→ search_quote_history]
        T6[calculate_quote\n→ catalog unit prices\n  bulk discount tiers]
    end

    subgraph Sales["Sales Agent — fulfillment only"]
        SA[Sales Agent]
        T7[finalize_sale\n→ create_transaction\n  get_stock_level]
        T8[estimate_delivery_date\n→ get_supplier_delivery_date]
        T9[get_financial_status\n→ generate_financial_report]
    end

    DB[(SQLite DB\ninventory · transactions\nquotes · quote_requests)]

    REQ --> ORCH
    ORCH --> IA --> T1 & T2 & T3 & T4
    ORCH --> QA --> T5 & T6
    ORCH --> SA --> T7 & T8 & T9
    T1 & T2 & T3 & T4 --> DB
    T5 --> DB
    T7 & T9 --> DB
    T2 -.-> SA
    IA --> ORCH
    QA --> ORCH
    SA --> ORCH
    ORCH --> RESP
